{
  "permissions": {
    "allow": [
      "Bash(git ls-files *)",
      "Bash(git -C * ls-files *)",
      "Bash(git -C * ls-files)"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(gh pr create *)",
      "Bash(rm *)",
      "Bash(gh api *)"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "clear|logout|prompt_input_exit|other",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/reflect-enqueue.sh"
          }
        ]
      }
    ]
  },
  "model": "sonnet",
  "askUserQuestionTimeout": "never",
  "effortLevel": "medium"
}
