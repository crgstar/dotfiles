#!/usr/bin/env python3
"""Claude Code の会話履歴（.jsonl）を人間が読める形式で出力する。"""

import argparse
import json
import re
import sys


def match(text: str, pattern: str) -> bool:
    return bool(re.search(pattern, text, re.IGNORECASE))


def extract_blocks(path: str, show_thinking: bool) -> list[dict]:
    """jsonlから表示用ブロックのリストを生成する。"""
    blocks = []
    with open(path, encoding="utf-8") as f:
        for line in f:
            if not line.strip():
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                # ライブ追記中のjsonlは書き込み途中で切れた行が混ざるためスキップする
                continue
            t = obj.get("type")
            content = obj.get("message", {}).get("content", [])

            if t == "user":
                if isinstance(content, str):
                    text = content
                elif isinstance(content, list):
                    text = "".join(
                        c["text"] for c in content
                        if c.get("type") == "text"
                    )
                else:
                    text = ""
                # `<` で始まるのは system-reminder などの XML 形式のメタ情報なので除外
                if text and not text.startswith("<"):
                    blocks.append({"role": "user", "text": text})

            elif t == "assistant":
                if isinstance(content, list):
                    for c in content:
                        if c.get("type") == "thinking" and c.get("thinking") and show_thinking:
                            blocks.append({"role": "thinking", "text": c["thinking"]})
                        elif c.get("type") == "text" and c.get("text"):
                            blocks.append({"role": "assistant", "text": c["text"]})

    return blocks


SEPARATOR = "─" * 60


def format_block(block: dict) -> list[str]:
    """ブロックを行のリストに変換する。"""
    role = block["role"]
    text = block["text"]
    if role == "user":
        return ["=== USER ==="] + text.splitlines()
    if role == "assistant":
        return ["=== ASSISTANT ==="] + text.splitlines()
    if role == "thinking":
        return ["--- thinking ---"] + text.splitlines() + ["--- /thinking ---"]
    raise ValueError(f"unknown role: {role}")


def print_block(block: dict, start_lineno: int, with_separator: bool = True, show_number: bool = False) -> None:
    lines = format_block(block)
    if with_separator:
        print(SEPARATOR)
    for i, line in enumerate(lines):
        if show_number:
            print(f"{start_lineno + i}\t{line}")
        else:
            print(line)


USAGE = "usage: claude-history [-n] [--separator] [--no-thinking] [--grep-user=PAT] [--grep-assistant=PAT] [-AN] [-BN] <file.jsonl>"


class _KeepFirst(argparse.Action):
    """複数回指定された場合は最初の指定を採用する（旧実装の next() が先頭一致を優先していたのに合わせる）。"""

    def __call__(self, parser, namespace, values, option_string=None):
        seen_attr = f"_{self.dest}_seen"
        if not getattr(namespace, seen_attr, False):
            setattr(namespace, self.dest, values)
            setattr(namespace, seen_attr, True)


def build_parser() -> argparse.ArgumentParser:
    # allow_abbrev=False: 旧実装は完全一致のフラグしか認識しなかったため、
    # 部分一致(略記)を許すと未知フラグの黙殺という旧バグを別形で温存してしまう
    parser = argparse.ArgumentParser(prog="claude-history", allow_abbrev=False)
    parser.add_argument("file", nargs="?", default=None)
    parser.add_argument("-n", dest="show_number", action="store_true")
    parser.add_argument("--separator", dest="show_separator", action="store_true")
    parser.add_argument("--no-thinking", dest="no_thinking", action="store_true")
    parser.add_argument("--grep-user", dest="grep_user", default=None, action=_KeepFirst)
    parser.add_argument("--grep-assistant", dest="grep_assistant", default=None, action=_KeepFirst)
    parser.add_argument("-A", dest="after", type=int, default=0, action=_KeepFirst)
    parser.add_argument("-B", dest="before", type=int, default=0, action=_KeepFirst)
    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    if args.file is None:
        print(USAGE, file=sys.stderr)
        sys.exit(1)

    # 空パターンは全ブロック非マッチとなり出力が無言で空になるため、誤入力として明示的に弾く
    if args.grep_user == "":
        parser.error("--grep-user のパターンが空です")
    if args.grep_assistant == "":
        parser.error("--grep-assistant のパターンが空です")

    show_thinking = not args.no_thinking
    show_number = args.show_number
    show_separator = args.show_separator
    grep_user = args.grep_user
    grep_assistant = args.grep_assistant
    after = args.after
    before = args.before

    blocks = extract_blocks(args.file, show_thinking)

    # 各ブロックの開始行番号を事前計算（grep前の全出力ベース）
    linenos = []
    lineno = 1
    for b in blocks:
        linenos.append(lineno)
        lineno += len(format_block(b))

    # grepなしはそのまま全出力
    if grep_user is None and grep_assistant is None:
        for i, b in enumerate(blocks):
            print_block(b, linenos[i], with_separator=show_separator, show_number=show_number)
        return

    # マッチするブロックのインデックスを収集
    matched = set()
    for i, b in enumerate(blocks):
        if grep_user and b["role"] == "user" and match(b["text"], grep_user):
            matched.add(i)
        if grep_assistant and b["role"] == "assistant" and match(b["text"], grep_assistant):
            matched.add(i)

    # before/after を展開し、連続したインデックスをグループ化
    ranges = []
    for i in sorted(matched):
        start = max(0, i - before)
        end = min(len(blocks), i + after + 1)
        if ranges and start <= ranges[-1][1]:
            # 前のグループと重なる/連続する場合は統合
            ranges[-1] = (ranges[-1][0], max(ranges[-1][1], end))
        else:
            ranges.append((start, end))

    # -A/-B未指定でuserのみgrepの場合はassistantを除外するフィルタ
    only_user = grep_user and grep_assistant is None and after == 0 and before == 0

    for start, end in ranges:
        group_blocks = [
            (i, blocks[i]) for i in range(start, end)
            if not (only_user and blocks[i]["role"] != "user")
        ]
        for pos, (i, b) in enumerate(group_blocks):
            # グループの先頭にだけ区切り線（--separator指定時）
            print_block(b, linenos[i], with_separator=(show_separator and pos == 0), show_number=show_number)


if __name__ == "__main__":
    main()
