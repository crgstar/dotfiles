#!/usr/bin/env bash
# git sweep: 内容が default branch に保全されたローカルブランチを掃除する
#
# 判定: <name> の先端が origin/<default> から到達可能なら削除、それ以外は残す。
# Why: GitHub の "Automatically delete head branches" が ON/OFF どちらでも同じ挙動になる。
#      git 単独で判定が完結し、gh / merged PR 情報にも依存しない。
#      squash / rebase merge は取りこぼすので、その運用では別途。
#
# git sweep             削除を実行
# git sweep --dry-run   候補を表示するだけ
set -u

dry_run=0
case "${1:-}" in
  --dry-run|-n) dry_run=1 ;;
  "") ;;
  *) echo "usage: git sweep [--dry-run]" >&2; exit 2 ;;
esac

def=$(git symbolic-ref -q --short refs/remotes/origin/HEAD)
def=${def#origin/}
[ -z "$def" ] && def=main
cur=$(git symbolic-ref -q --short HEAD || true)
if [ "$cur" != "$def" ]; then
  echo "sweep: デフォルトブランチ ($def) 以外では実行しません (現在: ${cur:-detached HEAD})"
  exit 1
fi

git fetch --prune || exit 1

# default 以外のローカルブランチを、origin/<default> 到達可能なら削除候補にする
deletable=""
kept=""
while IFS= read -r name; do
  [ "$name" = "$def" ] && continue
  if git merge-base --is-ancestor "$name" "origin/$def" 2>/dev/null; then
    deletable="$deletable $name"
  else
    kept="$kept $name"
  fi
done < <(git for-each-ref --format='%(refname:short)' refs/heads)

if [ "$dry_run" = 1 ]; then
  if [ -n "$deletable" ]; then
    echo "削除予定:"
    for n in $deletable; do echo "  $n"; done
  else
    echo "削除予定: なし"
  fi
  if [ -n "$kept" ]; then
    echo "残す (origin/$def 未到達 = 未マージ作業の可能性):"
    for n in $kept; do echo "  $n"; done
  fi
  exit 0
fi

if [ -z "$deletable" ]; then
  echo "sweep: 削除対象なし"
  exit 0
fi

# ブランチ名に空白は使えないため、素の for で安全に回せる
for n in $deletable; do
  if out=$(git branch -D "$n" 2>&1); then
    echo "sweep: $n を削除しました"
  else
    echo "sweep: $n の削除に失敗: $out" >&2
  fi
done
